# ============================================================
# TravelTalk 환경변수 설정 템플릿
# .env 파일을 프로젝트 루트에 생성하고 아래 값을 채워 넣으세요.
# ============================================================

# --- AdMob Ad Unit IDs ---
# Google AdMob 콘솔에서 생성한 광고 단위 ID
# 테스트 시에는 Google 공식 테스트 ID 사용:
#   Banner Android: ca-app-pub-3940256099942544/6300978111
#   Interstitial Android: ca-app-pub-3940256099942544/1033173712
ADMOB_BANNER_AD_UNIT_ID_ANDROID=
ADMOB_BANNER_AD_UNIT_ID_IOS=
ADMOB_INTERSTITIAL_AD_UNIT_ID_ANDROID=
ADMOB_INTERSTITIAL_AD_UNIT_ID_IOS=
ADMOB_REWARDED_AD_UNIT_ID_ANDROID=
ADMOB_REWARDED_AD_UNIT_ID_IOS=

# --- Cloud Functions Proxy ---
# Firebase Functions 배포 후 URL (예: https://us-central1-project-id.cloudfunctions.net)
PROXY_BASE_URL=

# --- Firebase ---
FIREBASE_PROJECT_ID=

# --- In-App Purchase Product IDs ---
IAP_PREMIUM_MONTHLY_ID=premium_monthly
IAP_PREMIUM_YEARLY_ID=premium_yearly
